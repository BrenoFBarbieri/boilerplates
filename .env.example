# --- ENVIRONMENT ---
# The environment the app is running in (development, staging, production)
NODE_ENV=development
APP_PORT=3000
APP_URL=
# Request timeout in miliseconds
APP_TIMEOUT=30000
# Request body limit (prevents giant payload attacks)
APP_BODY_LIMIT=1mb

# --- LOGGING ---
LOG_LEVEL=debug

# --- SECURITY ---
# Secret key for JWT signing (at least 32 characters recommended)
JWT_SECRET=your_ultra_secure_and_long_secret_here
# Token expiration time (e.g., 1h, 7d)
JWT_EXPIRES_IN=3h

# --- DATABASE (Example for PostgreSQL) ---
DATABASE_URL=postgres://user:password@host:port/db_name
# Maximum number of simultaneous connections that this API node can open
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- EXTERNAL SERVICES (Example) ---
# Sentry DSN for error tracking
SENTRY_DSN=
# API Key for SendGrid/Mailchimp
MAIL_SERVICE_API_KEY=your_service_key
