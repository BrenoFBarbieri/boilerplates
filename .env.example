# --- APP CONFIGURATION ---
# The environment the app is running in (development, staging, production)
NODE_ENV=development
# Port number for the local server
PORT=3000
# Base URL for the application
APP_URL=http://localhost:3000

# --- DATABASE (Example for PostgreSQL) ---
# Connection string: postgres://user:password@host:port/db_name
DATABASE_URL=postgres://postgres:postgres@localhost:5432/node_ts_db

# --- SECURITY ---
# Secret key for JWT signing (at least 32 characters recommended)
JWT_SECRET=your_ultra_secure_and_long_secret_here
# Token expiration time (e.g., 1h, 7d)
JWT_EXPIRES_IN=1h

# --- EXTERNAL SERVICES (Example) ---
# Sentry DSN for error tracking
SENTRY_DSN=
# API Key for SendGrid/Mailchimp
MAIL_SERVICE_API_KEY=your_service_key
