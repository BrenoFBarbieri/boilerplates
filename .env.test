# --- ENVIRONMENT ---
NODE_ENV=test
APP_PORT=3001
APP_URL=http://localhost:3001
# Short timeout to prevent tests from being "stuck" if somenthing fails
APP_TIMEOUT=5000
APP_BODY_LIMIT=1mb

# --- LOGGING ---
LOG_LEVEL=silent

# --- SECURITY ---
# Fixed secrets make it easier to mock tokens in unit tests
JWT_SECRET=test_secret_only_for_unit_testing
JWT_EXPIRES_IN=1s

# --- DATABASE ---
# Dedicated database to prevent developer data from being deleted due to human error
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_db
