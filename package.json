{
  "name": "node-ts-base-clean",
  "version": "1.0.0",
  "description": "A curated boilerplate designed to kickstart Node.js projects with a clean and efficient setup.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "imports": {
    "#/*": "./dist/*"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "test": "node --import tsx --env-file=.env.test --test",
    "test:watch": "node --import tsx --env-file=.env.test --test --watch",
    "test:coverage": "c8 --reporter=html --reporter=text npm test",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrenoFBarbieri/boilerplates.git"
  },
  "keywords": [],
  "author": "Breno Barbieri",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
