{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false /* Enables JS file generation for production */,
    "declaration": true /* Generates .d.ts files (essential for library consumers) */,
    "removeComments": true /* Strips comments to reduce bundle size */,
    "sourceMap": false /* Disables source maps for a cleaner production build */
  },
  "exclude": [
    /* Ensures test files are not included in the final distribution */
    "src/**/*.test.ts",
    "node_modules",
    "dist",
    "coverage"
  ]
}
